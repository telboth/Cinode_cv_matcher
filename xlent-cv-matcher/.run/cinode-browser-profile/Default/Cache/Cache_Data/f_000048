0000000-0000-0000-0000-000000000000","translatedState":0,"language":null},{"name":"LLM","level":4,"keywordId":0,"favourite":false,"keywordTypeName":"Techniques","keywordTypeId":0,"numberOfDaysWorkExperience":null,"lastWorkExperienceDate":null,"keywordSynonymId":121456,"blockItemId":"00000000-0000-0000-0000-000000000000","id":"00000000-0000-0000-0000-000000000000","disabled":true,"order":0,"isIncluded":false,"parentBlockItemId":102571,"profileBlockItemId":102571,"updated":null,"parentBlockItemUpdated":null,"blockId":"00000000-0000-0000-0000-000000000000","translatedState":0,"language":null}],"blockItemId":"00000000-0000-0000-0000-000000000000","id":"00000000-0000-0000-0000-000000000000","disabled":false,"order":0,"isIncluded":false,"parentBlockItemId":1214484,"profileBlockItemId":1214484,"updated":null,"parentBlockItemUpdated":null,"blockId":"10b5a3c2-4527-4419-9aba-004fb2945dfb","translatedState":0,"language":"Norwegian"},{"title":"Prosjekter som konsulent for Amesto NextBridge","description":"Hos Amesto NextBridge leverte konsulenten flere avanserte dataanalyse‑ og AI‑prosjekter for ulike kunder innen både privat og offentlig sektor. Arbeidet hadde hovedfokus på utvikling av maskinlæringsløsninger, bruk av moderne AI‑teknologier og innovative datadrevne produkter.\n\nEt av de mest fremtredende prosjektene var utviklingen av en løsning som analyserte og dekodet bieadferd ved hjelp av YOLO‑basert tracking, PyTorch og visuelle datamodeller. Dette prosjektet vant SAS EMEA Hackathon 2020 og ble fremhevet som et eksempel på kreativ og effektiv bruk av AI i praktiske problemstillinger. Konsulenten hadde ansvar for modellutvikling, databehandling og innsiktsvisualisering i Power BI.\n\nKonsulenten ledet også prosjekter innen prediksjon av fremtidige strømpriser og råvarepriser. Arbeidet involverte utvikling av tidsseriemodeller og treningspipelines basert på Keras, TensorFlow og PyTorch. Modellene ble benyttet av kundene for å styrke beslutningsgrunnlag og risikoanalyser i markeder med høy volatilitet.\n\nI tillegg gjennomførte konsulenten tidlig eksperimentering med LLM‑teknologi for Røde Kors, som en av de første i Norge med API‑tilgang til ChatGPT 3.0 allerede i 2019. Målet var å effektivisere interne prosesser ved hjelp av språkmodeller, og prosjektet bidro til å demonstrere hvordan generativ AI kan støtte humanitære organisasjoner i operativt arbeid.\n\nGjennom disse prosjektene kombinerte konsulenten teknisk dybde med evnen til å lede og gjennomføre innovasjonsprosjekter som ga konkrete, målbare gevinster for kundene.\n\nRolle: Lead Data Scientist","descriptionHtml":"<p>Hos Amesto NextBridge leverte konsulenten flere avanserte dataanalyse‑ og AI‑prosjekter for ulike kunder innen både privat og offentlig sektor. Arbeidet hadde hovedfokus på utvikling av maskinlæringsløsninger, bruk av moderne AI‑teknologier og innovative datadrevne produkter.</p><p><br></p><p>Et av de mest fremtredende prosjektene var utviklingen av en løsning som analyserte og dekodet bieadferd ved hjelp av YOLO‑basert tracking, PyTorch og visuelle datamodeller. Dette prosjektet vant SAS EMEA Hackathon 2020 og ble fremhevet som et eksempel på kreativ og effektiv bruk av AI i praktiske problemstillinger. Konsulenten hadde ansvar for modellutvikling, databehandling og innsiktsvisualisering i Power BI.</p><p><br></p><p>Konsulenten ledet også prosjekter innen prediksjon av fremtidige strømpriser og råvarepriser. Arbeidet involverte utvikling av tidsseriemodeller og treningspipelines basert på Keras, TensorFlow og PyTorch. Modellene ble benyttet av kundene for å styrke beslutningsgrunnlag og risikoanalyser i markeder med høy volatilitet.</p><p><br></p><p>I tillegg gjennomførte konsulenten tidlig eksperimentering med LLM‑teknologi for Røde Kors, som en av de første i Norge med API‑tilgang til ChatGPT 3.0 allerede i 2019. Målet var å effektivisere interne prosesser ved hjelp av språkmodeller, og prosjektet bidro til å demonstrere hvordan generativ AI kan støtte humanitære organisasjoner i operativt arbeid.</p><p><br></p><p>Gjennom disse prosjektene kombinerte konsulenten teknisk dybde med evnen til å lede og gjennomføre innovasjonsprosjekter som ga konkrete, målbare gevinster for kundene.</p><p><br></p><p>Rolle: Lead Data Scientist</p>","employer":null,"location":null,"skillsHeading":null,"sortYear":0,"startDate":"2019-01-01T00:00:00","endDate":"2020-02-29T00:00:00","isCurrent":false,"url":null,"useLogotype":false,"logotype":null,"projectId":0,"projectAssignmentId":null,"projectAssignment":null,"skills":[],"blockItemId":"00000000-0000-0000-0000-000000000000","id":"00000000-0000-0000-0000-000000000000","disabled":false,"order":0,"isIncluded":false,"parentBlockItemId":1214840,"profileBlockItemId":1214840,"updated":null,"parentBlockItemUpdated":null,"blockId":"10b5a3c2-4527-4419-9aba-004fb2945dfb","translatedState":0,"language":"Norwegian"},{"title":"Data Scientist / Geofysiker","description":"Thomas Elboth designet og ledet prosjekt i CGG der formålet var å trene dype neurale nettverk (CNNs) til å prosessere seismiske data for O&G industrien. Prosjektet gå svært gode resultater, og metodikken nyttes i dag i økende grad innen hele industrien.\nMetodikk: Python, Keras + signal/bilde behandling.","descriptionHtml":"<p>Thomas Elboth designet og ledet prosjekt i CGG der formålet var å trene dype neurale nettverk (CNNs) til å prosessere seismiske data for O&amp;G industrien. Prosjektet gå svært gode resultater, og metodikken nyttes i dag i økende grad innen hele industrien.</p><p>Metodikk: Python, Keras + signal/bilde behandling.</p>","employer":"CGG","location":{"locationId":543966,"googleId":"ChIJOfBn8mFuQUYRmh4j019gkn4","name":"Oslo","street":null,"streetNumber":null,"zipCode":null,"city":"Oslo","country":"Norway","countryCode":"NO","formattedAddress":"Oslo, Norway","phoneNumber":null,"latitude":"59.9121746","longitude":"10.7312704","webSiteUrl":null,"displayName":"Oslo, Norway","cityOrDisplayName":"Oslo"},"skillsHeading":null,"sortY