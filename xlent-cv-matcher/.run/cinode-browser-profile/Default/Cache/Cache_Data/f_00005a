        font-weight: 600;
    }

    .download-progress__error {
        display: none;
        flex-direction: column;
    }

    .download-progress__error p:first-of-type {
        font-size: 20px;
        font-weight: 600;
        line-height: 22px;
    }

    .download-progress__status {
        margin-left: auto;
    }

    .download-progress__status--loading,
    .download-progress__status--done,
    .download-progress__status--error {
        display: none;
    }

