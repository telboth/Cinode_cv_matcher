        color: white;
        font-size: 20px;
        font-weight: 700;
    }

    .download-progress__spinner--bg {
        fill: #c7c7c7;
    }

    .download-progress__spinner--rotate {
        animation: rotate 0.75s infinite linear;
        fill: #007db8;
        transform-origin: center;
    }

