# Local configuration
OPENAI_API_KEY=
USE_OPENAI_ANALYSIS=false
OPENAI_MODEL=gpt-4.1-mini
OPENAI_ALLOWED_MODELS=gpt-5.5,gpt-5.5-pro,gpt-5.4,gpt-5.4-mini,gpt-5.4-nano,gpt-4.1,gpt-4.1-mini,gpt-4o,gpt-4o-mini,o4-mini
CINODE_BASE_URL=
CINODE_API_TOKEN=Basic <base64(access_id:access_secret)>
CINODE_PUBLISH_PATH=/v0.1/companies/{companyId}/users/{companyUserId}/profile/import
ENABLE_CINODE_PUBLISH=false
CINODE_UI_AUTOMATION_ENABLED=false
CINODE_APP_URL=https://app.cinode.com
CINODE_UI_HEADLESS=true
CINODE_UI_TIMEOUT_MS=120000
CINODE_UI_STRICT_DETERMINISTIC_DEFAULT=true
