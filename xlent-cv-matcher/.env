# Local configuration
OPENAI_API_KEY=sk-
USE_OPENAI_ANALYSIS=true
OPENAI_MODEL=gpt-4.1-mini
OPENAI_ALLOWED_MODELS=gpt-4.1-mini,gpt-4.1,gpt-4o-mini,gpt-4o,o4-mini
CINODE_BASE_URL=https://api.cinode.com
CINODE_API_TOKEN=
CINODE_PUBLISH_PATH=/v0.1/companies/{companyId}/users/{companyUserId}/profile/import
ENABLE_CINODE_PUBLISH=true
CINODE_UI_AUTOMATION_ENABLED=true
CINODE_APP_URL=https://app.cinode.com
CINODE_UI_HEADLESS=false
CINODE_UI_TIMEOUT_MS=120000




